{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["../../node_modules/.prisma/client"],
      "@prisma/client/*": ["../../node_modules/.prisma/client/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["prisma.config.ts", "prisma/**", "dist", "node_modules"]
}
